class Board:
    def __init__(self):
        self.board = [
            [False, False, False, False, False, False, False, False],
            [False, False, False, False, False, False, False, False],
            [False, False, False, False, False, False, False, False],
            [False, False, False, False, False, False, False, False],
            [False, False, False, False, False, False, False, False],
            [False, False, False, False, False, False, False, False],
            [False, False, False, False, False, False, False, False],
            [False, False, False, False, False, False, False, False],
        ]

    def rows_range(self):
        return range(len(self.board[0]))

    def columns_range(self):
        return range(len(self.board))

    def __str__(self):
        lines = ["  +---+---+---+---+---+---+---+---+"]

        for row_number, row in enumerate(self.board):
            squares = []
            for column_number, has_queen in enumerate(row):
                if has_queen:
                    squares.append(" Q ")
                elif (row_number + column_number) % 2 == 0:
                    squares.append("   ")
                else:
                    squares.append(" . ")

            rank = 8 - row_number
            lines.append(f"{rank} |" + "|".join(squares) + "|")
            lines.append("  +---+---+---+---+---+---+---+---+")

        lines.append("    a   b   c   d   e   f   g   h")
        return "\n".join(lines)

    def add_queen(self, column, row):
        new_board = Board()
        new_board.board = [row.copy() for row in self.board]
        new_board.board[row][column] = True
        return new_board

    def is_save(self, column, row):
        if not self.row_is_safe(row):
            return False
        if not self.diagonals_are_safe(column, row):
            return False
        return True

    def row_is_safe(self, row):
        return not any(self.board[row])

    def diagonals_are_safe(self, column, row):
        return (
            self.diagonal_is_safe(column, row, -1, -1)
            and self.diagonal_is_safe(column, row, 1, -1)
            and self.diagonal_is_safe(column, row, -1, 1)
            and self.diagonal_is_safe(column, row, 1, 1)
        )

    def diagonal_is_safe(self, column, row, column_step, row_step):
        column += column_step
        row += row_step

        while column in self.columns_range() and row in self.rows_range():
            if self.board[row][column]:
                return False

            column += column_step
            row += row_step

        return True


def at_the_end_of_board(column):
    return column == 8


def add_column(column, all_solutions, board=None):
    if board is None:
        board = Board()

    if at_the_end_of_board(column):
        all_solutions.append(board)
        return all_solutions

    for row in board.rows_range():
        if board.is_save(column, row):
            new_board = board.add_queen(column, row)
            add_column(column + 1, all_solutions, new_board)

    return all_solutions


def all_eight_queens():
    all_solutions = []

    all_solutions = add_column(0, all_solutions)

    return all_solutions


def main():
    for board in all_eight_queens():
        print(board)
        print()


if __name__ == "__main__":
    main()
